# ============================================
# CONFIGURACIÓN DE SUPABASE
# ============================================
# Credenciales públicas de Supabase (seguras de exponer)
VITE_SUPABASE_PROJECT_ID="tu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="tu-publishable-key"
VITE_SUPABASE_URL="tu-supabase-url"

# ============================================
# CONFIGURACIÓN DE BLOCKCHAIN (WAGMI + RAINBOWKIT)
# ============================================

# RPC URL para Polygon Amoy Testnet
# IMPORTANTE: Usar endpoints públicos o privados en .env.local
# NO compartir claves de API privadas en el repositorio
VITE_POLYGON_AMOY_RPC="https://polygon-rpc.com"

# WalletConnect Project ID (obtener en https://cloud.walletconnect.com)
# Requerido para conexiones de wallet avanzadas
VITE_WALLETCONNECT_PROJECT_ID="tu-wallet-connect-project-id"

# ============================================
# CONFIGURACIÓN DE DESARROLLO (HARDHAT)
# ============================================

# Private key del deployer (SOLO en .env.local, NUNCA en repositorio)
DEPLOYER_PRIVATE_KEY="tu-private-key-aqui"

# API Key de PolygonScan (opcional, para verificar contratos)
POLYGONSCAN_API_KEY="tu-polygonscan-api-key"

# RPC avanzada de Alchemy para Polygon Amoy (opcional)
# Usa esto solo en desarrollo, en .env.local
VITE_POLYGON_AMOY_RPC_ALCHEMY="https://polygon-amoy.g.alchemy.com/v2/tu-key"

# ============================================
# NOTAS DE SEGURIDAD
# ============================================
# 1. Variables prefijadas con VITE_ están disponibles en el cliente (frontend)
# 2. NO incluir claves privadas en variables VITE_*
# 3. Usar .env.local para datos sensibles (incluido en .gitignore)
# 4. Cambiar VITE_POLYGON_AMOY_RPC al endpoint privado en producción
# 5. Revisar que ninguna private key esté committeada en git
